# Phase 0
QVAC_MODELS_CACHE_DIR=./.qvac-models
# MedPsy variant: 1.7B (~1GB, default) or 4B (~2.6GB)
MEDPSY_MODEL=1.7B
# Set true to block startup until MedPsy is loaded (not recommended)
PRELOAD_MEDPSY=false
# Optional HuggingFace token if downloads fail or rate-limit
# HF_TOKEN=

# Phase 1 — Database
DATABASE_URL=
DATABASE_DIRECT_URL=

# BullMQ job queue (required by API)
REDIS_URL=

# Phase 1 — Auth (generate with: node scripts/generate-jwt-keys.js)
JWT_PRIVATE_KEY_FILE=.jwt-private.pem
JWT_PUBLIC_KEY_FILE=.jwt-public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Privy (passwordless auth)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Frontend (Vite)
VITE_PRIVY_APP_ID=
VITE_API_URL=/api

# App
NODE_ENV=development
APP_ENV=development
APP_PORT=3000
QVAC_NODE_PORT=3001
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
QVAC_NODE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:5173

# Phase 2
QVAC_HYPERSWARM_SEED=
QVAC_NODE_SECRET=
EVIDENCE_DIR=./evidence

# Telegram Caregiver Companion
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false
TELEGRAM_LINK_TOKEN_TTL_SEC=900
