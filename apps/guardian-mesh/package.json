{
  "name": "@kinkeeper/guardian-mesh-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server.js": "./dist/server.js"
  },
  "scripts": {
    "build": "npm run build:ui && tsc -p tsconfig.json",
    "build:ui": "npm install --prefix ui && npm run build --prefix ui",
    "dev": "dotenv -e ../../.env --override -- tsx watch src/main.ts",
    "dev:ui": "npm run dev --prefix ui",
    "start": "dotenv -e ../../.env --override -- node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm run typecheck --prefix ui"
  },
  "dependencies": {
    "@kinkeeper/guardian-mesh": "*",
    "@kinkeeper/qvac": "*",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
